{
  "name": "ddd-toolkit",
  "version": "1.0.0",
  "private": false,
  "description": "Zero-dependency DDD building blocks for TypeScript: Result, Option, Entity, Aggregate, ValueObject, domain events and repository ports.",
  "type": "module",
  "license": "MIT",
  "author": "axelhamil",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/axelhamil/ddd-toolkit.git"
  },
  "bugs": {
    "url": "https://github.com/axelhamil/ddd-toolkit/issues"
  },
  "homepage": "https://github.com/axelhamil/ddd-toolkit#readme",
  "keywords": [
    "ddd",
    "domain-driven-design",
    "clean-architecture",
    "result",
    "option",
    "entity",
    "aggregate",
    "value-object",
    "domain-events",
    "repository",
    "typescript",
    "esm"
  ],
  "packageManager": "pnpm@11.5.2",
  "engines": {
    "node": ">=24"
  },
  "sideEffects": false,
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "files": [
    "dist",
    "!dist/*.map"
  ],
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsdown",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --fix .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "check": "biome check . && pnpm typecheck",
    "prepublishOnly": "pnpm build"
  },
  "devDependencies": {
    "@arethetypeswrong/core": "^0.18.3",
    "@biomejs/biome": "^2.4.16",
    "@types/node": "^24.7.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@vitest/coverage-v8": "^4.1.8",
    "publint": "^0.3.21",
    "semantic-release": "^25.0.3",
    "tsdown": "^0.22.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
